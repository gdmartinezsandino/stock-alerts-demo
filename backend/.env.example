# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database (matches docker-compose) ---
# When running the API on the host with Postgres in Docker:
DATABASE_URL=postgresql://stock:stock@localhost:5432/stockdb?schema=public
# When running the API itself inside docker-compose, the host is the service name:
# DATABASE_URL=postgresql://stock:stock@db:5432/stockdb?schema=public

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Finnhub (get a free key at https://finnhub.io/dashboard) ---
FINNHUB_API_KEY=your_finnhub_api_key_here
# Comma-separated symbols tracked live + used as the alert universe.
TRACKED_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA,META,NVDA,NFLX

# --- Firebase Cloud Messaging (optional) ---
# Path to the service-account JSON downloaded from the Firebase console.
# Leave empty to run FCM in dry-run mode (pushes are logged, not sent).
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
